{
  "name": "budget-base-api",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "npm run build && concurrently -k -n TSC,API -c yellow,cyan \"npm run dev:compile\" \"npm run dev:serve\"",
    "dev:compile": "tsc -w -p tsconfig.json --preserveWatchOutput",
    "dev:serve": "node --watch dist/main.js",
    "build": "npm run prisma:generate && tsc -p tsconfig.json --incremental false",
    "typecheck:scripts": "tsc -p tsconfig.scripts.json --incremental false",
    "start": "node dist/main.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "repl": "tsx scripts/repl.ts",
    "db:import:sqlite": "tsx scripts/import-sqlite.ts",
    "db:import:sqlite:dry-run": "tsx scripts/import-sqlite.ts --dry-run"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/graphql": "^13.2.5",
    "@nestjs/mercurius": "^13.2.5",
    "@nestjs/platform-fastify": "^11.0.20",
    "@prisma/client": "^6.18.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "better-sqlite3": "^12.9.0",
    "concurrently": "^9.2.1",
    "graphql": "^16.13.2",
    "jose": "^6.1.0",
    "mercurius": "^16.9.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "prisma": "^6.18.0",
    "tsx": "^4.21.0"
  }
}
